GM_PIN=change-this-before-running-a-real-session
NODE_ENV=production
HOST=0.0.0.0
PORT=4173
# Optional: set this to a Railway Volume path to persist runtime data across deploys.
# DATA_DIR=/data

# Optional: send a gzip-compressed, recoverable JSON backup to an off-site HTTP endpoint.
# URL placeholders {date} and {timestamp} are replaced for every backup.
# OFFSITE_BACKUP_URL=https://backup.example/kunibayashi/{timestamp}.json.gz
# OFFSITE_BACKUP_TOKEN=replace-with-endpoint-token
# OFFSITE_BACKUP_METHOD=PUT
# OFFSITE_BACKUP_INTERVAL_MINUTES=1440
